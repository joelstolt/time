# Resend — transaktionsmail för bokningsformulären (/api/send).
#
# Skaffa en API-nyckel på https://resend.com/api-keys och lägg den i
# Vercel -> Project Settings -> Environment Variables som RESEND_API_KEY
# (Production + Preview). Kopiera denna fil till .env.local för lokal
# utveckling.
#
# Innan det funkar i prod: verifiera domänen `timeoutservice.se` i Resend
# så att from-adressen `noreply@timeoutservice.se` godkänns (SPF/DKIM).

RESEND_API_KEY=
